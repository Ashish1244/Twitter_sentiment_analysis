import pandas as pd
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.linear_model import LogisticRegression
from sklearn.metrics import classification_report, accuracy_score

# 1. Load the Data
# The CSV files lack a header row, so we explicitly define the column names
columns = ["ID", "Entity", "Sentiment", "Tweet"]

print("Loading datasets...")
train_df = pd.read_csv("twitter_training.csv", header=None, names=columns)
val_df = pd.read_csv("twitter_validation.csv", header=None, names=columns)

# 2. Data Preprocessing
# Drop any rows where the Tweet text is missing (NaN)
train_df = train_df.dropna(subset=["Tweet"])
val_df = val_df.dropna(subset=["Tweet"])

# Separate the input features (text) and the target variable (sentiment)
X_train = train_df["Tweet"]
y_train = train_df["Sentiment"]

X_val = val_df["Tweet"]
y_val = val_df["Sentiment"]

# 3. Text Vectorization
# Convert the raw text into numerical features using TF-IDF.
# We remove standard English stop words and limit features to the top 10,000 terms for efficiency.
print("Vectorizing text data...")
vectorizer = TfidfVectorizer(stop_words="english", max_features=10000)

X_train_tfidf = vectorizer.fit_transform(X_train)
X_val_tfidf = vectorizer.transform(X_val)

# 4. Model Training
# Initialize and train a Logistic Regression classifier
print("Training the Logistic Regression model...")
model = LogisticRegression(max_iter=1000, random_state=42)
model.fit(X_train_tfidf, y_train)

# 5. Model Evaluation
# Predict the sentiments on the validation set and evaluate the results
print("Evaluating model performance...\n")
y_pred = model.predict(X_val_tfidf)

accuracy = accuracy_score(y_val, y_pred)
print(f"Validation Accuracy: {accuracy * 100:.2f}%\n")

print("Classification Report:")
print(classification_report(y_val, y_pred))

# 6. Example Usage (Inference)
sample_tweets = [
    "I absolutely love the new design, it's fantastic!",
    "My experience with this product has been terrible and frustrating.",
    "I just bought a coffee from the store."
]

sample_tfidf = vectorizer.transform(sample_tweets)
predictions = model.predict(sample_tfidf)

print("\nSample Predictions:")
for tweet, sentiment in zip(sample_tweets, predictions):
    print(f"- Tweet: '{tweet}' --> Sentiment: {sentiment}")


import pandas as pd
import numpy as np
import tensorflow as tf
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Embedding, LSTM, Dense, SpatialDropout1D, Dropout
from tensorflow.keras.preprocessing.text import Tokenizer
from tensorflow.keras.preprocessing.sequence import pad_sequences
from sklearn.preprocessing import LabelEncoder
from sklearn.metrics import classification_report, accuracy_score

# 1. Load the Data
columns = ["ID", "Entity", "Sentiment", "Tweet"]

print("Loading datasets...")
train_df = pd.read_csv("twitter_training.csv", header=None, names=columns)
val_df = pd.read_csv("twitter_validation.csv", header=None, names=columns)

# 2. Data Preprocessing
# Drop missing tweets
train_df = train_df.dropna(subset=["Tweet"])
val_df = val_df.dropna(subset=["Tweet"])

X_train = train_df["Tweet"].astype(str)
y_train = train_df["Sentiment"]

X_val = val_df["Tweet"].astype(str)
y_val = val_df["Sentiment"]

# 3. Label Encoding
# LSTMs require numerical labels. We convert text sentiments to integers (0, 1, 2, 3)
encoder = LabelEncoder()
y_train_encoded = encoder.fit_transform(y_train)
y_val_encoded = encoder.transform(y_val)

# 4. Text Tokenization and Padding
MAX_WORDS = 15000  # Number of unique words to keep
MAX_LEN = 100      # Max length of each tweet (in words)

print("Tokenizing and padding sequences...")
tokenizer = Tokenizer(num_words=MAX_WORDS, oov_token="<OOV>")
tokenizer.fit_on_texts(X_train)

# Convert text to sequences of integers
X_train_seq = tokenizer.texts_to_sequences(X_train)
X_val_seq = tokenizer.texts_to_sequences(X_val)

# Pad sequences so they all have exactly MAX_LEN length
X_train_padded = pad_sequences(X_train_seq, maxlen=MAX_LEN, padding='post', truncating='post')
X_val_padded = pad_sequences(X_val_seq, maxlen=MAX_LEN, padding='post', truncating='post')

# 5. Build the LSTM Architecture
print("Building the LSTM model...")
model = Sequential([
    # Embedding layer learns a dense vector representation for each word
    Embedding(input_dim=MAX_WORDS, output_dim=128, input_length=MAX_LEN),
    
    # Drops entire 1D feature maps to prevent overfitting
    SpatialDropout1D(0.2),
    
    # LSTM layer with 64 units
    LSTM(64, dropout=0.2, recurrent_dropout=0.2),
    
    # Fully connected dense layer
    Dense(64, activation='relu'),
    Dropout(0.2),
    
    # Output layer: 4 nodes (one for each class) with softmax for probability distribution
    Dense(4, activation='softmax')
])

# Compile the model
model.compile(loss='sparse_categorical_crossentropy', 
              optimizer='adam', 
              metrics=['accuracy'])

model.summary()

# 6. Train the Model
print("\nTraining the model (this may take a while depending on your hardware)...")
# Using a few epochs for demonstration; you can increase this for better performance
history = model.fit(X_train_padded, y_train_encoded, 
                    epochs=5, 
                    batch_size=128, 
                    validation_data=(X_val_padded, y_val_encoded))

# 7. Model Evaluation
print("\nEvaluating model performance...")
y_pred_probs = model.predict(X_val_padded)
# Get the index of the highest probability class
y_pred_encoded = np.argmax(y_pred_probs, axis=1)

accuracy = accuracy_score(y_val_encoded, y_pred_encoded)
print(f"\nValidation Accuracy: {accuracy * 100:.2f}%\n")

# Decode numerical labels back to text for the report
target_names = encoder.classes_
print("Classification Report:")
print(classification_report(y_val_encoded, y_pred_encoded, target_names=target_names))

# 8. Example Usage (Inference)
sample_tweets = [
    "I absolutely love the new design, it's fantastic!",
    "My experience with this product has been terrible and frustrating.",
    "I just bought a coffee from the store."
]

# Preprocess the new text exactly like the training data
sample_seq = tokenizer.texts_to_sequences(sample_tweets)
sample_padded = pad_sequences(sample_seq, maxlen=MAX_LEN, padding='post', truncating='post')

# Predict
sample_probs = model.predict(sample_padded)
sample_preds = np.argmax(sample_probs, axis=1)
predicted_sentiments = encoder.inverse_transform(sample_preds)

print("\nSample Predictions:")
for tweet, sentiment in zip(sample_tweets, predicted_sentiments):
    print(f"- Tweet: '{tweet}' --> Sentiment: {sentiment}")


